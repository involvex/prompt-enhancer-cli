{
	"printWidth": 80,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"singleAttributePerLine": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"jsxBracketSameLine": false,
	"arrowParens": "avoid",
	"plugins": [
		"prettier-plugin-organize-imports",
		"prettier-plugin-packagejson",
		"prettier-plugin-sort-imports"
	]
}
